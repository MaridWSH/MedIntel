# MedIntel environment configuration
# Copy this file to .env and adjust values for your environment.

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------

# API base URL for the frontend (Next.js). Must be publicly accessible.
NEXT_PUBLIC_API_BASE=https://med.aidashnews.tech/api

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------

# PostgreSQL connection URL used by SQLAlchemy.
# For local development without Docker, you can use SQLite:
# DATABASE_URL=sqlite:///./medintel.db
DATABASE_URL=postgresql+psycopg2://medintel:${POSTGRES_PASSWORD}@localhost:5432/medintel

# Docker Compose binds service ports to loopback by default. Change only when a
# firewall/reverse proxy is intentionally handling external access.
MEDINTEL_BIND_ADDRESS=127.0.0.1

# PostgreSQL credentials used by docker-compose.yaml
POSTGRES_USER=medintel
POSTGRES_PASSWORD=      # generate: python -c "import secrets; print(secrets.token_urlsafe(16))"
POSTGRES_DB=medintel

# -----------------------------------------------------------------------------
# Vector Database (Qdrant)
# -----------------------------------------------------------------------------

# Qdrant server URL.
# Use http://localhost:6333 when running Qdrant locally (or via Docker Compose).
# Use :memory: only for quick experiments with the qdrant-client local mode.
MEDINTEL_QDRANT_URL=http://localhost:6333

# Optional Qdrant API key (leave empty if not using authentication)
MEDINTEL_QDRANT_API_KEY=

# Name of the Qdrant collection that stores paper embeddings
MEDINTEL_QDRANT_COLLECTION=papers

# -----------------------------------------------------------------------------
# Embeddings
# -----------------------------------------------------------------------------

# Sentence-transformer model used for semantic search
MEDINTEL_EMBEDDING_MODEL=BAAI/bge-m3

# Embedding dimension produced by the model above (1024 for BGE-M3)
MEDINTEL_EMBEDDING_DIMENSION=1024

# Prefix added to search queries before embedding
MEDINTEL_QUERY_INSTRUCTION="Represent this sentence for searching relevant scientific papers: "

# Batch size used when generating embeddings during indexing
MEDINTEL_EMBEDDING_BATCH_SIZE=32

# Maximum source/summary characters embedded for one paper.
MEDINTEL_EMBEDDING_MAX_CHARS=12000

# Vector database request timeout.
MEDINTEL_QDRANT_TIMEOUT_SECONDS=10

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------

# Runtime mode: development, staging, or production. Production/staging refuse
# to start with a missing, short, or placeholder JWT secret.
MEDINTEL_ENV=development

# JWT secret key. Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
MEDINTEL_SECRET_KEY=

# Set to true in production — marks refresh cookie as Secure (HTTPS-only).
MEDINTEL_SECURE_COOKIES=false

# Comma-separated browser origins allowed by CORS and cookie-authenticated writes.
MEDINTEL_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://med.aidashnews.tech

# CIDR ranges for reverse proxies allowed to supply visitor-IP headers. Never
# trust 0.0.0.0/0; direct clients could then bypass per-IP rate limiting.
MEDINTEL_TRUSTED_PROXY_NETWORKS=127.0.0.1/32,::1/128

# Comma-separated account emails allowed to run ingestion/backfill endpoints.
# Keep maintenance endpoints inaccessible until at least one admin is configured.
MEDINTEL_ADMIN_EMAILS=

# Access tokens are short-lived; the HttpOnly refresh cookie renews them.
MEDINTEL_ACCESS_TOKEN_MINUTES=15

# API docs default off in production and on in development.
MEDINTEL_ENABLE_DOCS=true

# Only results from this reviewed pipeline contract are accepted by ingestion.
MEDINTEL_PIPELINE_VERSION=2026-07-14.2

# Defaults to true automatically in staging/production. When enabled, stale or
# unverified AI summaries are hidden from public responses.
MEDINTEL_REQUIRE_CURRENT_PIPELINE=true

# -----------------------------------------------------------------------------
# Email (Password Reset)
# -----------------------------------------------------------------------------

# SMTP server configuration for sending password reset emails.
# Leave empty to log reset tokens instead (for development/testing).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=noreply@med.aidashnews.tech
MEDINTEL_RESET_URL=https://med.aidashnews.tech/reset-password
